# ─────────────────────────────────────────────────────────────────────────────
# 7Bar PDV — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores corretos.
# NUNCA commite o .env real — ele contém senhas e segredos.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Servidor ─────────────────────────────────────────────────────────────────
# IP público do servidor de produção (Portainer/VPS)
# Para desenvolvimento local use: localhost
SERVER_IP=SEU_IP_AQUI

# ─── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=SENHA_FORTE_AQUI

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=SEGREDO_JWT_FORTE_AQUI

# ─── Setup PIN ────────────────────────────────────────────────────────────────
# PIN de acesso à página de inicialização do sistema (/sys-init)
SETUP_PIN=SEU_PIN_AQUI
