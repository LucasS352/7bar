// ============================================================
//  TENANT SCHEMA — Banco por empresa (multi-tenant)
//  Cada tenant tem seu próprio banco com esta estrutura
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL_TENANT")
}

// ------------------------------------------------------------
//  GrupoTributacao — regras fiscais por grupo de produtos
//  Baseado na estrutura GRUPO_TRIBUTACAO + TRIBUTACAO do Packon
// ------------------------------------------------------------
model GrupoTributacao {
  id    String @id @default(uuid())
  nome  String // ex: "TRIBUTADOS - Consumidor Final SP"
  ativo Boolean @default(true)

  // ICMS — Simples Nacional
  csosn     String? // 102=SN s/ crédito, 400=Isento ST, 500=ST recolhido
  // ICMS — Regime Normal
  cstIcms   String? // 00=Tributado, 10=Com ST, 20=Red BC, 60=ST retido...
  cfop      String  // 5102=Venda interna, 6108=Venda outra UF
  aliqIcms  Decimal @default(0) @db.Decimal(5, 2)

  // Redução de base de cálculo ICMS (quando aplicável)
  redBcIcms Decimal @default(0) @db.Decimal(5, 2)

  // PIS
  cstPis    String  @default("99") // 99=SN, 01=Tributado, 07=Isento...
  aliqPis   Decimal @default(0)    @db.Decimal(5, 2)

  // COFINS
  cstCofins String  @default("99")
  aliqCofins Decimal @default(0)   @db.Decimal(5, 2)

  // IPI (opcional — bebidas podem ter)
  cstIpi    String?
  aliqIpi   Decimal @default(0) @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]

  @@map("grupo_tributacao")
}

// ------------------------------------------------------------
//  Category — categorias de produto
// ------------------------------------------------------------
model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@map("categories")
}

// ------------------------------------------------------------
//  Product — cadastro completo com campos fiscais
//  Espelhado nos campos PRO_* do Packon identificados no Firebird
// ------------------------------------------------------------
model Product {
  id                  String           @id @default(uuid())
  categoryId          String
  category            Category         @relation(fields: [categoryId], references: [id])
  grupoTributacaoId   String?
  grupoTributacao     GrupoTributacao? @relation(fields: [grupoTributacaoId], references: [id])

  // Dados básicos
  name      String
  shortCode String?  @unique // código interno curto
  barcode   String?  @unique // EAN-13 / GTIN
  unit      String   @default("UN") // UN, KG, LT, CX, DZ, PCT...
  active    Boolean  @default(true)
  imageUrl  String?  @db.Text // URL da imagem do produto

  // Preços
  priceCost Decimal  @db.Decimal(10, 4) // custo
  priceSell Decimal  @db.Decimal(10, 4) // preço de venda

  // Estoque e Vendas
  stock     Decimal  @default(0) @db.Decimal(10, 3) // Decimal para fracionados
  salesCount Int     @default(0) // Contador de vendas para ranking no PDV

  // Campos Fiscais (NCM, CEST vindos do Packon PRO_NCM / PRO_CEST)
  ncm     String? // 8 dígitos — obrigatório para NFC-e
  cest    String? // 7 dígitos — quando há ST
  origem  Int     @default(0)
  // 0=Nacional, 1=Estrangeiro import direta, 2=Estrangeiro adquirido no mercado interno

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItems     SaleItem[]
  inventoryLogs InventoryLog[]

  @@map("products")
}

// ------------------------------------------------------------
//  Customer — consumidor (destinatário da NFC-e)
// ------------------------------------------------------------
model Customer {
  id        String  @id @default(uuid())
  name      String
  phone     String  @unique
  cpfCnpj   String? // CPF ou CNPJ (identificação na NFC-e)
  address   String?
  reference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales Sale[]

  @@map("customers")
}

// ------------------------------------------------------------
//  Operator — colaboradores da empresa
// ------------------------------------------------------------
model Operator {
  id        String   @id @default(uuid())
  name      String
  pin       String   // PIN hasheado do operador (ex: Julio)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales         Sale[]
  cashRegisters CashRegister[]

  @@map("operators")
}

// ------------------------------------------------------------
//  Sale — cabeçalho da venda + dados NFC-e
// ------------------------------------------------------------
model Sale {
  id             String        @id @default(uuid())
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  operatorId     String?       // ID do colaborador
  operator       Operator?     @relation(fields: [operatorId], references: [id])
  cashRegisterId String?
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id])

  // Valores
  subtotal Decimal @default(0) @db.Decimal(10, 2)
  discount Decimal @default(0) @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  // Status da venda
  status String @default("completed") // completed, cancelled

  // NFC-e — dados de emissão
  emitirNfce Boolean @default(false)  // o operador escolheu emitir?
  nfceStatus String? // pendente, autorizada, rejeitada, cancelada, nao_emitida

  // Dados retornados pelo microsserviço PHP após autorização
  nfceNumero      Int?    // número sequencial da nota
  nfceSerie       Int?    // série
  nfceChave       String? @unique // chave de acesso 44 dígitos
  nfceProtocolo   String? // número do protocolo SEFAZ
  nfceAutorizadaEm DateTime?

  // Armazenamento do resultado
  nfceXml    String? @db.LongText // XML completo autorizado
  nfceQrcode String? @db.Text     // URL do QR Code

  // Erro (quando rejeitada)
  nfceCodRejeicao    String?
  nfceMotivoRejeicao String? @db.Text // Mensagens SEFAZ podem ser longas

  // CPF do consumidor informado na emissão (opcional)
  consumidorCpf  String?
  consumidorNome String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    SaleItem[]
  payments Payment[]

  @@index([createdAt])
  @@map("sales")
}

// ------------------------------------------------------------
//  SaleItem — itens da venda com SNAPSHOT fiscal imutável
//  Os tributos são congelados no momento da venda
//  (conformidade fiscal — nota não pode ser recalculada)
// ------------------------------------------------------------
model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  // Snapshot do produto no momento da venda
  productName String  @default("") // nome no momento da venda
  unit        String  @default("UN")
  quantity    Decimal @db.Decimal(10, 3)
  priceUnit   Decimal @db.Decimal(10, 4)
  discount    Decimal @default(0) @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)

  // Snapshot fiscal (congelado — NÃO alterar após criação)
  ncm        String? // NCM do produto na hora da venda
  cest       String? // CEST
  cfop       String? // CFOP aplicado
  origem     Int     @default(0)

  // ICMS (Simples Nacional ou Regime Normal — apenas um será preenchido)
  csosn      String? // Simples Nacional: 102, 400, 500...
  cstIcms    String? // Regime Normal: 00, 10, 20, 60...
  aliqIcms   Decimal @default(0) @db.Decimal(5, 2)
  valorIcms  Decimal @default(0) @db.Decimal(10, 2)

  // PIS
  cstPis     String  @default("99")
  aliqPis    Decimal @default(0) @db.Decimal(5, 2)
  valorPis   Decimal @default(0) @db.Decimal(10, 2)

  // COFINS
  cstCofins  String  @default("99")
  aliqCofins Decimal @default(0) @db.Decimal(5, 2)
  valorCofins Decimal @default(0) @db.Decimal(10, 2)

  @@map("sale_items")
}

// ------------------------------------------------------------
//  Payment — formas de pagamento com código tPag SEFAZ
// ------------------------------------------------------------
model Payment {
  id     String @id @default(uuid())
  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  // tPag — código oficial SEFAZ (Tab. 5.4)
  // 01=Dinheiro, 03=Cartão Crédito, 04=Cartão Débito, 17=PIX, 99=Outros
  tPag   String  @default("99")
  method String // label amigável: cash, credit, debit, pix, other
  value  Decimal @db.Decimal(10, 2)
  troco  Decimal @default(0) @db.Decimal(10, 2)

  @@map("payments")
}

// ------------------------------------------------------------
//  CashRegister — abertura e fechamento de caixa
// ------------------------------------------------------------
model CashRegister {
  id           String    @id @default(uuid())
  operatorId   String?   // ID do colaborador
  operator     Operator? @relation(fields: [operatorId], references: [id])
  openingTime  DateTime  @default(now())
  closingTime  DateTime?
  openingValue Decimal   @default(0) @db.Decimal(10, 2)
  closingValue Decimal?  @db.Decimal(10, 2)
  status       String    @default("open") // open, closed

  movements CashMovement[]
  sales     Sale[]

  @@index([status])
  @@map("cash_registers")
}

// ------------------------------------------------------------
//  CashMovement — suprimento e sangria
// ------------------------------------------------------------
model CashMovement {
  id             String       @id @default(uuid())
  cashRegisterId String
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])

  type      String  // IN=suprimento, OUT=sangria
  value     Decimal @db.Decimal(10, 2)
  reason    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("cash_movements")
}

// ------------------------------------------------------------
//  InventoryLog — histórico de movimentações de estoque
// ------------------------------------------------------------
model InventoryLog {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  type      String  // IN=entrada, OUT=ajuste saída, SALE=venda PDV
  quantity  Decimal @db.Decimal(10, 3)
  costPrice Decimal? @db.Decimal(10, 4)
  reason    String?

  createdAt DateTime @default(now())

  @@map("inventory_logs")
}

// ------------------------------------------------------------
//  NumeracaoNfce — controle sequencial de numeração por série
//  Garante sequência sem gaps (exigência SEFAZ)
// ------------------------------------------------------------
model NumeracaoNfce {
  id     String  @id @default(uuid())
  serie  Int
  ultimo Int     @default(0) // último número emitido

  @@unique([serie])
  @@map("numeracao_nfce")
}

// ------------------------------------------------------------
//  TenantSettings — configurações globais do tenant
//  Tabela de linha única (singleton), gerenciada via upsert
// ------------------------------------------------------------
model TenantSettings {
  id                 String  @id @default("singleton")
  /// Permite que o PDV finalize vendas mesmo com estoque zerado ou negativo
  allowNegativeStock Boolean @default(false)
  /// PIN numérico (hasheado) para autorizar descontos no PDV
  discountPin        String? 

  @@map("tenant_settings")
}
