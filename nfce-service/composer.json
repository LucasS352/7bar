{
    "name": "7bar/nfce-service",
    "description": "Microsserviço PHP para emissão de NFC-e via sped-nfe (SEFAZ-SP)",
    "version": "1.0.0",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "slim/slim": "^4.13",
        "slim/psr7": "^1.7",
        "nfephp-org/sped-nfe": "^5.0",
        "nfephp-org/sped-common": "^5.0",
        "monolog/monolog": "^3.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    }
}
